{"nodes": [{"id": "docs_architecture", "label": "xPST Architecture", "file_type": "document", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_sources_layer", "label": "Sources Layer", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Downloads videos from source platforms via the VideoSource interface; yt-dlp chosen for TikTok as most reliable and actively maintained, with browser cookies for HD quality and flat playlist extraction for fast metadata."}, {"id": "docs_architecture_platforms_layer", "label": "Platforms Layer", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uploads videos via the PlatformUploader interface (YouTube, X/Twitter, Instagram); each platform has research-verified optimal encoding settings."}, {"id": "docs_architecture_engine_layer", "label": "Engine Layer", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Orchestrates fetch, filter, download, encode, upload, track; per-platform circuit breakers, state persistence after each video, catch-up logic for sleep/wake."}, {"id": "docs_architecture_state_management", "label": "State Management", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Persistent JSON state with atomic writes (temp then rename), backup rotation (keep 5), corruption recovery via backup fallback, and versioned schema for migration; never lose track of posted videos."}, {"id": "docs_architecture_circuit_breaker_pattern", "label": "Circuit Breaker Pattern", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prevents cascading failures with CLOSED/OPEN/HALF_OPEN states; configurable failure threshold (5) and reset window (3600s); auto-disables failing platforms so one failure does not block others."}, {"id": "docs_architecture_retry_logic", "label": "Retry Logic", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exponential backoff with jitter handles transient failures; QUICK_RETRY, STANDARD_RETRY, and AGGRESSIVE_RETRY presets."}, {"id": "docs_architecture_video_processing", "label": "Video Processing Pipeline", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FFmpeg-based platform-optimized encoding instead of one-size re-encoding: YouTube passthrough, Instagram 720p CRF23 Main@L3.0 fixed GOP 72 bt709, X 1080p 10Mbps High@L4.0 with yuv420p required and keyint 90."}, {"id": "docs_architecture_plugin_architecture", "label": "Plugin Architecture", "file_type": "rationale", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "New platforms and sources are added by implementing abstract base classes (PlatformUploader, VideoSource) and registering in PlatformRegistry/SourceRegistry, keeping the engine platform-agnostic and extensible."}, {"id": "docs_architecture_security_model", "label": "Security Model", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Credentials local in ~/.xpst/credentials/ and gitignored; OAuth2 for YouTube, cookies for X via twikit, session for Instagram via instagrapi; no data sent to external servers except target platforms; state files hold metadata only."}, {"id": "docs_architecture_ffmpeg", "label": "FFmpeg", "file_type": "concept", "source_file": "docs/ARCHITECTURE.md", "source_location": null, "source_url": "https://ffmpeg.org/", "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_architecture", "target": "docs_architecture_sources_layer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_platforms_layer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_engine_layer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_state_management", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_circuit_breaker_pattern", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_retry_logic", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_video_processing", "relation