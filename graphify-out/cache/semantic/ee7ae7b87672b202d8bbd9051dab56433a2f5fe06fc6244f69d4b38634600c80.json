{"nodes": [{"id": "docs_install", "label": "Installation Guide", "file_type": "document", "source_file": "docs/INSTALL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_install_macos_support", "label": "macOS Platform Support", "file_type": "concept", "source_file": "docs/INSTALL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "macOS supported via Homebrew (python@3.12, ffmpeg); OS scheduler uses a LaunchAgent in ~/Library/LaunchAgents/; desktop app via PySide6."}, {"id": "docs_install_linux_support", "label": "Linux Platform Support", "file_type": "concept", "source_file": "docs/INSTALL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ubuntu/Debian via apt and Fedora/RHEL via dnf (python3, pip, ffmpeg); keyring needs gnome-keyring or falls back to encrypted files; OS scheduler adds a crontab entry."}, {"id": "docs_install_windows_support", "label": "Windows Platform Support", "file_type": "concept", "source_file": "docs/INSTALL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Python from python.org with PATH, FFmpeg via winget or manual PATH; pip install xpst[windows] extras; OS scheduler creates a Scheduled Task."}, {"id": "docs_install_docker_deployment", "label": "Docker Deployment", "file_type": "concept", "source_file": "docs/INSTALL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "docker build then run with ~/.xpst volume mount; docker-compose runs watch --interval 900 with restart unless-stopped."}, {"id": "docs_install_pypi_install", "label": "PyPI Installation", "file_type": "concept", "source_file": "docs/INSTALL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null,