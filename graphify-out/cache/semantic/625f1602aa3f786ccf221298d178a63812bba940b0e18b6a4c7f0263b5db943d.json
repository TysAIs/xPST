{"nodes": [{"id": "docs_adr", "label": "Architecture Decision Records", "file_type": "document", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_adr_adr_001_use_case_layer_di", "label": "ADR-001: Use-Case Layer with Dependency Injection", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Business logic was mixed with infrastructure (I/O, API calls, state), making testing hard and blocking parallel execution; extracting pure use-case classes with constructor DI gives mock testability, parallel execution, and clean separation, at the cost of more files and a contributor learning curve."}, {"id": "docs_adr_adr_002_statemanager_split", "label": "ADR-002: StateManager Split (Store vs Manager)", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Original StateManager mixed atomic file I/O, corruption recovery, and business logic; split into StateStore (pure I/O, locking, recovery) and StateManager (video tracking, DLQ, statistics) for single responsibility, swappable storage backends, and easier testing, kept backward compatible via wrapper."}, {"id": "docs_adr_adr_003_sessionmanager_single_auth", "label": "ADR-003: SessionManager as Single Auth Source", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each uploader/source duplicated credential loading (~244 lines) causing inconsistent behavior and multiple auth paths; centralizing in SessionManager.get_*_client() yields a single source of truth, consistent error handling, easier new auth methods, and removed ~200 duplicate lines."}, {"id": "docs_adr_adr_004_encrypted_credential_fallback", "label": "ADR-004: Encrypted Credential Fallback", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When the OS keychain is unavailable credentials were plain JSON; Fernet encryption with argon2id key derivation (.enc files, per-file keys from a master key) gives defense in depth and works on headless servers, at the cost of key-management complexity and slower first access."}, {"id": "docs_adr_adr_005_cli_agent_readiness", "label": "ADR-005: CLI Agent-Readiness", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CLI was designed for humans only; adding --json, --quiet, --dry-run, auto-JSON when stdout is not a TTY, and meaningful exit codes (0,1,2,3,4,10) makes it AI-agent, CI/CD, and scripting friendly per Unix philosophy."}, {"id": "docs_adr_adr_006_mcp_server", "label": "ADR-006: MCP Server for AI Integration", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Needed to expose xPST to AI assistants (Claude, Cursor); a stdio-based MCP server with posting/health/config/auth tools provides native AI integration over a standard discoverable protocol, at the cost of requiring the mcp package."}, {"id": "docs_adr_adr_007_prometheus_metrics", "label": "ADR-007: Prometheus Metrics", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Production deployments need observability; optional prometheus_client metrics (uploads counter, upload/encoding duration histograms, active platforms and circuit breaker gauges at /metrics) are industry standard, zero cost if not installed, and work with Grafana/Alertmanager."}, {"id": "docs_adr_adr_008_config_migration", "label": "ADR-008: Config Migration System", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Config schema evolves; versioned migrations (v1 to v4) run automatically on load with timestamped backups in ~/.xpst/backups/, enabling zero-downtime upgrades, rollback, and a clear audit trail, but migration logic must be idempotent."}, {"id": "docs_adr_adr_009_circuit_breaker", "label": "ADR-009: Circuit Breaker Pattern", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Platform APIs fail intermittently; per-platform 3-state circuit breakers (closed/open with 5-min fail-fast/half-open) persisted in the state file give automatic failure isolation, self-healing, and metric observability, though they may delay recovery."}, {"id": "docs_adr_adr_010_anti_bot", "label": "ADR-010: Anti-Bot Human-Like Behavior", "file_type": "rationale", "source_file": "docs/adr.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Social platforms detect and block automation; configurable jittered delays, per-platform user agents, browser cookie extraction for auth, and wake checks reduce false positives at the cost of throughput, with no guarantee of safety."}], "edges": [{"source": "docs_adr", "target": "docs_adr_adr_001_use_case_layer_di", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr.md", "source_location": null, "weight": 1.0}, {"source": "docs_adr", "target": "docs_adr_adr_002_statemanager_split", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr.md", "source_location": null, "wei