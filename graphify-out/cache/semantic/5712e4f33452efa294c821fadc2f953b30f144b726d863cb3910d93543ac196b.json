{"nodes": [{"id": "readme_xpst_overview", "label": "xPST Cross-Platform Studio (README)", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_bidirectional_cross_posting", "label": "Bidirectional Cross-Posting", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Differentiator vs one-direction tools: every connected platform acts as both source and destination; content-hash deduplication prevents double-posting when content circulates in all directions."}, {"id": "readme_local_first_security", "label": "Local-First Zero-Trust Model", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core product stance: free forever, no cloud servers, content and credentials never leave the machine, no third-party OAuth sharing (users bring their own Google Cloud project and browser cookies). This eliminates subscription lock-in and removes the vendor as a data custodian."}, {"id": "readme_anti_bot_protection", "label": "Anti-Bot Protection", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Randomized delays, time-of-day awareness, caption variation, User-Agent rotation, randomized platform order, and conservative 5/day defaults exist to mitigate ban risk inherent to the unofficial-API integrations \u2014 explicitly framed as risk reduction, not a guarantee."}, {"id": "readme_circuit_breaker_pattern", "label": "Circuit Breaker Pattern", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Auto-disables failing platforms after a threshold (default 5 failures) and auto-recovers after a reset window (default 3600s) so one platform's outage never blocks the others (graceful degradation)."}, {"id": "readme_provider_agnostic_core", "label": "Provider-Agnostic Core / Provider Manifest", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sources and destinations publish machine-readable capability manifests (roles, capabilities, auth mode, docs URL, risk notes) consumed uniformly by CLI, desktop app, MCP server, diagnostics, and release tooling \u2014 so new providers plug in without touching the engine."}, {"id": "readme_mcp_server", "label": "xPST MCP Server", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "stdio-transport MCP server exposing xPST to AI agents. README lists 9 tools (xpst_providers ... xpst_delete); CHANGELOG and AGENTS.md say 8 tools + 3 resources \u2014 tool count drifted between docs. Metadata tools are deliberately lightweight and do not start the posting engine."}, {"id": "readme_ffmpeg", "label": "FFmpeg", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "External binary dependency (not a Python package) used for per-platform video encoding; must be on PATH or set via XPST_FFMPEG_PATH. Installed explicitly in CI on all three OSes."}], "edges": [{"source": "readme_xpst_overview", "target": "readme_bidirectional_cross_posting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_xpst_overview", "target": "readme_local_first_security", "relation": "references", "confidence": "