{"nodes": [{"id": "docs_post_scheduling_design", "label": "Post Scheduling System Design", "file_type": "document", "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_post_scheduling_design_schedule_store", "label": "ScheduleStore", "file_type": "code", "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Persistent storage for ScheduledPost records in ~/.xpst/schedule.json using the same atomic-write pattern as StateManager, with file locking and backup rotation (3)."}, {"id": "docs_post_scheduling_design_post_scheduler", "label": "PostScheduler", "file_type": "code", "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Asyncio loop polling ScheduleStore every 30s for due posts; enforces anti-bot posting windows and per-platform rate limits; up to 2 retries with 30-minute delay; resets interrupted running posts to pending on restart."}, {"id": "docs_post_scheduling_design_custom_async_scheduler", "label": "Decision: Custom Async Scheduler over APScheduler", "file_type": "rationale", "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "APScheduler adds dependency and complexity (job stores, executors, triggers) that is not needed; xPST already has robust atomic-JSON state persistence and a simple poll-loop Scheduler, so a lightweight asyncio timer loop is simpler, easier to debug, fits the existing architecture, and requires zero new dependencies (stdlib only)."}, {"id": "docs_post_scheduling_design_timezone_handling", "label": "Timezone Handling Strategy", "file_type": "concept", "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All times stored as ISO 8601 with timezone offset using stdlib zoneinfo for IANA names; UTC internally, user-timezone display only; protects against clock skew and DST transitions."}, {"id": "docs_post_scheduling_design_anti_bot_window", "label": "Anti-Bot Posting Window Enforcement", "file_type": "concept", "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Posting allowed 8am-11pm (configurable); out-of-window posts are warned at scheduling time, deferred at execution time to next morning, and given +/-5 min jitter so nothing posts exactly on the hour."}], "edges": [{"source": "docs_post_scheduling_design", "target": "docs_post_scheduling_design_schedule_store", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "docs_post_scheduling_design", "target": "docs_post_scheduling_design_post_scheduler", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "docs_post_scheduling_design", "target": "docs_post_scheduling_design_custom_async_scheduler", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "docs_post_scheduling_design", "target": "docs_post_scheduling_design_timezone_handling", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/POST_SCHEDULING_DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "docs_post_scheduling_design", "target": "docs_post_scheduling_design_anti_bot_window", "relation"