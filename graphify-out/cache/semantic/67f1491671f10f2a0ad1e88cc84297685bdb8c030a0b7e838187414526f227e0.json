{"nodes": [{"id": "docs_roadmap_v2", "label": "xPST v2.0 Roadmap", "file_type": "document", "source_file": "docs/ROADMAP_V2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_roadmap_v2_vision", "label": "v2.0 Vision: Universal Cross-Platform Content Manager", "file_type": "rationale", "source_file": "docs/ROADMAP_V2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One tool to post from ANY platform to ALL others; upload once, distribute everywhere; free, local, open source, bulletproof."}, {"id": "docs_roadmap_v2_phase1_multi_source", "label": "Phase 1: Multi-Source Support", "file_type": "concept", "source_file": "docs/ROADMAP_V2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Any platform as source, not just TikTok: download from Instagram, TikTok, YouTube, X, and local files (xpst pull --from instagram --to all)."}, {"id": "docs_roadmap_v2_phase2_carousel_support", "label": "Phase 2: Carousel Support", "file_type": "concept", "source_file": "docs/ROADMAP_V2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Instagram native album_upload (up to 20 items), X thread creation via reply_to, YouTube/TikTok compiled to a single video with FFmpeg because TikTok has no free photo API."}, {"id": "docs_roadmap_v2_phase3_analytics_dashboard", "label": "Phase 3: Analytics Dashboard", "file_type": "concept", "source_file": "docs/ROADMAP_V2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "NiceGUI on localhost:8080 with per-post analytics: YouTube Analytics API v2, instagrapi insights, twikit tweet metrics, fragile tiktok-api scrape."}, {"id": "docs_roadmap_v2_phase4_source_detection", "label": "Phase 4: Source Detection",