# Version control
.git
.gitignore

# Python caches and build artifacts
__pycache__
*.pyc
*.pyo
.venv
venv
build
dist
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
.coverage

# Runtime data and user state (never ship into the image)
.xpst
release-smoke

# Secrets and credentials (never ship into the build context)
.env
.env.*
*token*.json
*cookies*.json
*.pem
*.key

# Local tooling / docs not needed at runtime
.github
docs
graphify-out
tests
